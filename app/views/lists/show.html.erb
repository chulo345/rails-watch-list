<h1><%= @list.name %> movies</h1>

<ul>
<% @list.bookmarks.each do |bookmark| %>
  <li><%= bookmark.movie.title %> -
  <%= link_to "Delete movie from list", bookmark_path(bookmark) %> - <%= link_to "Delete movie from list", bookmark_path(bookmark), data: {turbo_method: :delete, turbo_confirm: "Are you sure?"}  %></li>
<% end  %>
</ul>

<p> <%= link_to "Add movie to list", new_list_bookmark_path(@list) %></p>
<p> <%= link_to "Back to movie lists", root_path %></p>
